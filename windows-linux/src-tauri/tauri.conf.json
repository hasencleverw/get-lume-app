{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lume",
  "version": "1.0.0",
  "identifier": "com.hasenborges.lume",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Lume",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 1000,
        "minHeight": 660,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#0B0B1E",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Lume",
    "homepage": "https://getlu.me",
    "copyright": "Copyright © 2026 Lume",
    "targets": ["deb", "rpm", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Lightweight cleanup utility",
    "longDescription": "Lume frees memory, clears caches, finds large files, detects threats, manages apps and tunes performance — in one ~10 MB native binary.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libssl3",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "openssl",
          "gtk3",
          "libayatana-appindicator-gtk3"
        ]
      }
    }
  },
  "plugins": {}
}
